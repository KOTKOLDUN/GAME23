<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ocean Overlord - Survival Evolution Game</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            width: 100vw;
            height: 100vh;
            overflow: hidden;
            background: #001a2e;
            font-family: 'Arial', sans-serif;
            color: #fff;
        }

        canvas {
            display: block;
            background: linear-gradient(to bottom, #0a4a7a 0%, #001f3f 50%, #0d0d2b 100%);
        }

        /* UI OVERLAY STYLES */
        .ui-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 1000;
        }

        .ui-container.active {
            pointer-events: auto;
        }

        .hud {
            position: fixed;
            top: 20px;
            left: 20px;
            color: #00ff88;
            font-size: 18px;
            text-shadow: 0 0 10px rgba(0, 255, 136, 0.5);
            pointer-events: none;
        }

        .hud-item {
            margin-bottom: 15px;
        }

        .evolution-bar {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            width: 300px;
            height: 40px;
            background: rgba(0, 0, 0, 0.7);
            border: 2px solid #00ff88;
            border-radius: 20px;
            overflow: hidden;
            pointer-events: none;
        }

        .evolution-fill {
            height: 100%;
            background: linear-gradient(90deg, #00ff88, #00ccff);
            width: 0%;
            transition: width 0.3s ease;
        }

        .evolution-text {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: #fff;
            font-weight: bold;
            text-shadow: 0 0 5px rgba(0, 0, 0, 1);
            pointer-events: none;
        }

        .menu-screen {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 15, 40, 0.95);
            display: none;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            z-index: 2000;
            pointer-events: auto;
        }

        .menu-screen.active {
            display: flex;
        }

        .menu-title {
            font-size: 64px;
            color: #00ff88;
            margin-bottom: 40px;
            text-shadow: 0 0 20px rgba(0, 255, 136, 0.7);
        }

        .menu-button {
            width: 300px;
            height: 60px;
            margin: 15px 0;
            font-size: 22px;
            background: linear-gradient(135deg, #00ff88, #00ccff);
            color: #001a2e;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            font-weight: bold;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .menu-button:hover {
            transform: scale(1.05);
            box-shadow: 0 0 20px rgba(0, 255, 136, 0.5);
        }

        .menu-button:active {
            transform: scale(0.98);
        }

        .menu-content {
            text-align: center;
            max-height: 80vh;
            overflow-y: auto;
        }

        .menu-text {
            color: #00ff88;
            font-size: 16px;
            margin: 20px 0;
            max-width: 600px;
            line-height: 1.6;
        }

        .pause-menu {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: rgba(0, 15, 40, 0.95);
            border: 3px solid #00ff88;
            border-radius: 20px;
            padding: 40px;
            text-align: center;
            display: none;
            z-index: 1500;
            pointer-events: auto;
        }

        .pause-menu.active {
            display: block;
        }

        .pause-title {
            font-size: 48px;
            color: #00ff88;
            margin-bottom: 30px;
        }

        .game-over-screen {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.9);
            display: none;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            z-index: 2000;
            pointer-events: auto;
        }

        .game-over-screen.active {
            display: flex;
        }

        .game-over-title {
            font-size: 56px;
            color: #ff4444;
            margin-bottom: 30px;
            text-shadow: 0 0 20px rgba(255, 68, 68, 0.7);
        }

        .game-over-stats {
            font-size: 24px;
            color: #00ff88;
            margin: 15px 0;
            text-shadow: 0 0 10px rgba(0, 255, 136, 0.5);
        }

        .settings-menu {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: rgba(0, 15, 40, 0.95);
            border: 3px solid #00ff88;
            border-radius: 20px;
            padding: 40px;
            max-width: 500px;
            display: none;
            z-index: 1500;
            pointer-events: auto;
        }

        .settings-menu.active {
            display: block;
        }

        .settings-title {
            font-size: 36px;
            color: #00ff88;
            margin-bottom: 20px;
        }

        .settings-item {
            margin: 20px 0;
            text-align: left;
            color: #00ff88;
            font-size: 18px;
        }

        .toggle-switch {
            display: inline-block;
            width: 60px;
            height: 30px;
            background: #333;
            border-radius: 15px;
            cursor: pointer;
            margin-left: 10px;
            position: relative;
            transition: background 0.3s;
        }

        .toggle-switch.on {
            background: #00ff88;
        }

        .toggle-slider {
            position: absolute;
            top: 3px;
            left: 3px;
            width: 24px;
            height: 24px;
            background: white;
            border-radius: 50%;
            transition: left 0.3s;
        }

        .toggle-switch.on .toggle-slider {
            left: 33px;
        }

        /* CONTROLS SCREEN */
        .controls-screen {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 15, 40, 0.95);
            display: none;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            z-index: 2000;
            pointer-events: auto;
        }

        .controls-screen.active {
            display: flex;
        }

        .controls-content {
            text-align: center;
            color: #00ff88;
        }

        .controls-title {
            font-size: 48px;
            margin-bottom: 40px;
        }

        .control-item {
            font-size: 20px;
            margin: 15px 0;
            color: #00ccff;
        }

        .control-key {
            display: inline-block;
            background: #00ff88;
            color: #001a2e;
            padding: 5px 12px;
            border-radius: 5px;
            font-weight: bold;
            margin: 0 10px;
            min-width: 60px;
        }

        /* NOTIFICATION */
        .notification {
            position: fixed;
            top: 100px;
            left: 20px;
            background: rgba(0, 255, 136, 0.2);
            border: 2px solid #00ff88;
            color: #00ff88;
            padding: 15px 20px;
            border-radius: 10px;
            font-size: 16px;
            display: none;
            z-index: 999;
            animation: fadeInOut 3s ease-in-out forwards;
        }

        @keyframes fadeInOut {
            0% { opacity: 0; transform: translateY(-20px); }
            10% { opacity: 1; transform: translateY(0); }
            90% { opacity: 1; transform: translateY(0); }
            100% { opacity: 0; transform: translateY(-20px); }
        }

        @media (max-width: 1024px) {
            .hud { font-size: 14px; }
            .menu-title { font-size: 48px; }
            .menu-button { width: 250px; height: 50px; font-size: 18px; }
        }
    </style>
</head>
<body>
    <canvas id="gameCanvas"></canvas>
    
    <!-- UI CONTAINER -->
    <div class="ui-container">
        <!-- HUD -->
        <div class="hud" id="hud">
            <div class="hud-item">🏆 Score: <span id="scoreDisplay">0</span></div>
            <div class="hud-item">💰 Coins: <span id="coinsDisplay">0</span></div>
            <div class="hud-item">📊 Size: <span id="sizeDisplay">1.0</span></div>
            <div class="hud-item">🐟 Evolution: <span id="evolutionStageDisplay">Tiny Fish</span></div>
            <div class="hud-item">❤️ Health: <span id="healthDisplay">100%</span></div>
            <div class="hud-item">🌾 Hunger: <span id="hungerDisplay">100%</span></div>
            <div class="hud-item" style="margin-top: 30px; font-size: 14px; color: #00ccff;">
                <div>⌨️ WASD - Move</div>\n                <div>🖱️ Mouse - Aim</div>\n                <div>⬆️ Shift - Boost</div>\n                <div>🔫 Space - Attack</div>\n                <div>⏸️ ESC - Pause</div>\n            </div>\n        </div>\n\n        <!-- EVOLUTION BAR -->\n        <div class="evolution-bar" id="evolutionBar">\n            <div class="evolution-fill" id="evolutionFill"></div>\n            <div class="evolution-text" id="evolutionText">0%</div>\n        </div>\n    </div>\n\n    <!-- START MENU -->\n    <div class="menu-screen active" id="startMenu">\n        <div class="menu-content">\n            <div class="menu-title">🌊 OCEAN OVERLORD</div>\n            <div class="menu-text">Survive, Grow, Evolve. Become the Ultimate Predator of the Ocean.</div>\n            <button class="menu-button" onclick="gameEngine.startGame()">PLAY</button>\n            <button class="menu-button" onclick="menuSystem.showControls()">CONTROLS</button>\n            <button class="menu-button" onclick="menuSystem.showSettings()">SETTINGS</button>\n        </div>\n    </div>\n\n    <!-- CONTROLS SCREEN -->\n    <div class="controls-screen" id="controlsScreen">\n        <div class="controls-content">\n            <div class="controls-title">🎮 CONTROLS</div>\n            <div class="control-item">\n                <span class="control-key">W A S D</span> - Move your fish\n            </div>\n            <div class="control-item">\n                <span class="control-key">MOUSE</span> - Aim camera direction\n            </div>\n            <div class="control-item">\n                <span class="control-key">SHIFT</span> - Speed boost (costs hunger)\n            </div>\n            <div class="control-item">\n                <span class="control-key">SPACE</span> - Attack ability (when available)\n            </div>\n            <div class="control-item">\n                <span class="control-key">ESC</span> - Pause game\n            </div>\n            <div style="margin-top: 50px;">\n                <button class="menu-button" onclick="menuSystem.hideControls()">BACK</button>\n            </div>\n        </div>\n    </div>\n\n    <!-- PAUSE MENU -->\n    <div class="pause-menu" id="pauseMenu">\n        <div class="pause-title">⏸️ PAUSED</div>\n        <button class="menu-button" onclick="gameEngine.resume()">RESUME</button>\n        <button class="menu-button" onclick="gameEngine.returnToMenu()">MENU</button>\n        <button class="menu-button" onclick="menuSystem.showSettings()">SETTINGS</button>\n    </div>\n\n    <!-- SETTINGS MENU -->\n    <div class="settings-menu" id="settingsMenu">\n        <div class="settings-title">⚙️ SETTINGS</div>\n        <div class="settings-item">\n            Sound Effects\n            <div class="toggle-switch on" id="soundToggle" onclick="menuSystem.toggleSound()">\n                <div class="toggle-slider"></div>\n            </div>\n        </div>\n        <div class="settings-item">\n            Music\n            <div class="toggle-switch on" id="musicToggle" onclick="menuSystem.toggleMusic()">\n                <div class="toggle-slider"></div>\n            </div>\n        </div>\n        <div class="settings-item">\n            Particles\n            <div class="toggle-switch on" id="particlesToggle" onclick="menuSystem.toggleParticles()">\n                <div class="toggle-slider"></div>\n            </div>\n        </div>\n        <div style="margin-top: 30px;">\n            <button class="menu-button" onclick="menuSystem.hideSettings()">CLOSE</button>\n        </div>\n    </div>\n\n    <!-- GAME OVER SCREEN -->\n    <div class="game-over-screen" id="gameOverScreen">\n        <div class="game-over-title">GAME OVER</div>\n        <div class="game-over-stats">Final Score: <span id="finalScore">0</span></div>\n        <div class="game-over-stats">Total Coins: <span id="totalCoins">0</span></div>\n        <div class="game-over-stats">Max Evolution: <span id="maxEvolution">Tiny Fish</span></div>\n        <div class="game-over-stats">Survived: <span id="survivalTime">0s</span></div>\n        <button class="menu-button" style="margin-top: 30px;" onclick="gameEngine.requestRevive()">WATCH AD TO REVIVE</button>\n        <button class="menu-button" onclick="gameEngine.returnToMenu()">MAIN MENU</button>\n    </div>\n\n    <script>\n        // ==========================================\n        // OCEAN OVERLORD - MAIN GAME ENGINE\n        // ==========================================\n\n        const canvas = document.getElementById('gameCanvas');\n        const ctx = canvas.getContext('2d', { alpha: false });\n        \n        // Canvas setup for desktop\n        canvas.width = window.innerWidth;\n        canvas.height = window.innerHeight;\n        window.addEventListener('resize', () => {\n            canvas.width = window.innerWidth;\n            canvas.height = window.innerHeight;\n        });\n\n        // ==========================================\n        // CONFIGURATION\n        // ==========================================\n        const CONFIG = {\n            gameWidth: 4000,\n            gameHeight: 4000,\n            targetFPS: 60,\n            playerStartSize: 1,\n            maxPlayerSize: 50,\n            hungerDecayRate: 0.02,\n            boostCost: 0.5,\n            fishSchoolSize: 150,\n            predatorCount: 20,\n        };\n\n        // ==========================================\n        // YANDEX SDK INTEGRATION\n        // ==========================================\n        const yandexSDK = {\n            initialized: false,\n            ysdk: null,\n            player: null,\n            playerData: {},\n\n            init: async function() {\n                try {\n                    if (window.YaGames) {\n                        this.ysdk = await window.YaGames.init();\n                        this.player = await this.ysdk.getPlayer({ signed: false });\n                        this.playerData = await this.player.getData();\n                        this.initialized = true;\n                        console.log('Yandex SDK initialized');\n                        return true;\n                    }\n                } catch (error) {\n                    console.warn('Yandex SDK not available:', error);\n                }\n                return false;\n            },\n\n            saveProgress: function(stats) {\n                if (!this.initialized) return;\n                try {\n                    this.player.setData({\n                        maxScore: stats.maxScore,\n                        totalCoins: stats.totalCoins,\n                        maxEvolution: stats.maxEvolution,\n                    });\n                } catch (error) {\n                    console.warn('Failed to save progress:', error);\n                }\n            },\n        };\n\n        // ==========================================\n        // ADVERTISEMENT SYSTEM\n        // ==========================================\n        const adSystem = {\n            canShowInterstitial: true,\n            lastInterstitialTime: 0,\n            interstitialCooldown: 30000, // 30 seconds\n\n            showInterstitialAd: async function() {\n                const now = Date.now();\n                if (now - this.lastInterstitialTime < this.interstitialCooldown) return;\n                \n                this.lastInterstitialTime = now;\n                \n                if (yandexSDK.ysdk && yandexSDK.ysdk.adv) {\n                    try {\n                        await yandexSDK.ysdk.adv.showInterstitialAd();\n                        console.log('Interstitial ad shown');\n                    } catch (error) {\n                        console.warn('Interstitial ad failed:', error);\n                    }\n                } else {\n                    console.log('[AD] Interstitial Ad Placeholder');\n                }\n            },\n\n            showRewardedAd: async function(rewardType = 'revive') {\n                if (yandexSDK.ysdk && yandexSDK.ysdk.adv) {\n                    try {\n                        await yandexSDK.ysdk.adv.showRewardedVideo();\n                        console.log(`Rewarded ad shown: ${rewardType}`);\n                        return true;\n                    } catch (error) {\n                        console.warn('Rewarded ad failed:', error);\n                        return false;\n                    }\n                } else {\n                    console.log(`[AD] Rewarded Ad Placeholder: ${rewardType}`);\n                    return true; // Simulate success in development\n                }\n            },\n        };\n\n        // ==========================================\n        // PARTICLE SYSTEM\n        // ==========================================\n        class Particle {\n            constructor(x, y, velocityX, velocityY, color, life = 30) {\n                this.x = x;\n                this.y = y;\n                this.vx = velocityX;\n                this.vy = velocityY;\n                this.color = color;\n                this.life = life;\n                this.maxLife = life;\n                this.size = Math.random() * 3 + 1;\n            }\n\n            update() {\n                this.x += this.vx;\n                this.y += this.vy;\n                this.vy += 0.1; // gravity\n                this.life--;\n            }\n\n            draw(ctx, offsetX, offsetY) {\n                const alpha = this.life / this.maxLife;\n                ctx.globalAlpha = alpha;\n                ctx.fillStyle = this.color;\n                ctx.beginPath();\n                ctx.arc(this.x - offsetX, this.y - offsetY, this.size, 0, Math.PI * 2);\n                ctx.fill();\n                ctx.globalAlpha = 1;\n            }\n\n            isAlive() {\n                return this.life > 0;\n            }\n        }\n\n        const particleSystem = {\n            particles: [],\n\n            add: function(x, y, velocityX, velocityY, color, life) {\n                if (!menuSystem.settings.particles) return;\n                this.particles.push(new Particle(x, y, velocityX, velocityY, color, life));\n            },\n\n            addBubbles: function(x, y, count = 5) {\n                for (let i = 0; i < count; i++) {\n                    const angle = (Math.PI * 2 * i) / count;\n                    const speed = 2 + Math.random() * 2;\n                    this.add(\n                        x,\n                        y,\n                        Math.cos(angle) * speed,\n                        Math.sin(angle) * speed - 2,\n                        'rgba(200, 220, 255, 0.6)',\n                        40 + Math.random() * 20\n                    );\n                }\n            },\n\n            addBlood: function(x, y, count = 8) {\n                for (let i = 0; i < count; i++) {\n                    const angle = Math.random() * Math.PI * 2;\n                    const speed = 1 + Math.random() * 3;\n                    this.add(\n                        x,\n                        y,\n                        Math.cos(angle) * speed,\n                        Math.sin(angle) * speed,\n                        'rgba(255, 50, 50, 0.8)',\n                        30 + Math.random() * 20\n                    );\n                }\n            },\n\n            update: function() {\n                this.particles = this.particles.filter(p => p.isAlive());\n                this.particles.forEach(p => p.update());\n            },\n\n            draw: function(ctx, offsetX, offsetY) {\n                this.particles.forEach(p => p.draw(ctx, offsetX, offsetY));\n            },\n        };\n\n        // ==========================================\n        // COLLISION SYSTEM\n        // ==========================================\n        const collisionSystem = {\n            checkCircleCollision: function(x1, y1, r1, x2, y2, r2) {\n                const dx = x2 - x1;\n                const dy = y2 - y1;\n                const distance = Math.sqrt(dx * dx + dy * dy);\n                return distance < r1 + r2;\n            },\n\n            checkRectCollision: function(rect1, rect2) {\n                return (\n                    rect1.x < rect2.x + rect2.width &&\n                    rect1.x + rect1.width > rect2.x &&\n                    rect1.y < rect2.y + rect2.height &&\n                    rect1.y + rect1.height > rect2.y\n                );\n            },\n\n            getCollisionNormal: function(x1, y1, x2, y2) {\n                const dx = x2 - x1;\n                const dy = y2 - y1;\n                const length = Math.sqrt(dx * dx + dy * dy);\n                return { x: dx / length, y: dy / length };\n            },\n        };\n\n        // ==========================================\n        // FISH AI SYSTEM\n        // ==========================================\n        class Fish {\n            constructor(x, y, size, species = 'small') {\n                this.x = x;\n                this.y = y;\n                this.size = size;\n                this.species = species;\n                this.vx = (Math.random() - 0.5) * 2;\n                this.vy = (Math.random() - 0.5) * 2;\n                this.angle = Math.atan2(this.vy, this.vx);\n                this.speed = Math.random() * 1 + 0.5;\n                this.directionChangeTimer = 0;\n                this.health = 100;\n            }\n\n            update() {\n                this.directionChangeTimer--;\n                if (this.directionChangeTimer <= 0) {\n                    this.angle = Math.random() * Math.PI * 2;\n                    this.directionChangeTimer = 60 + Math.random() * 120;\n                }\n\n                this.vx = Math.cos(this.angle) * this.speed;\n                this.vy = Math.sin(this.angle) * this.speed;\n\n                this.x += this.vx;\n                this.y += this.vy;\n\n                // Boundary wrapping\n                if (this.x < 0) this.x = CONFIG.gameWidth;\n                if (this.x > CONFIG.gameWidth) this.x = 0;\n                if (this.y < 0) this.y = CONFIG.gameHeight;\n                if (this.y > CONFIG.gameHeight) this.y = 0;\n            }\n\n            draw(ctx, offsetX, offsetY) {\n                const screenX = this.x - offsetX;\n                const screenY = this.y - offsetY;\n\n                // Only draw if on screen\n                if (screenX < -50 || screenX > canvas.width + 50 ||\n                    screenY < -50 || screenY > canvas.height + 50) return;\n\n                ctx.save();\n                ctx.translate(screenX, screenY);\n                ctx.rotate(this.angle);\n\n                // Fish body\n                ctx.fillStyle = this.getSpeciesColor();\n                ctx.beginPath();\n                ctx.ellipse(0, 0, this.size, this.size * 0.6, 0, 0, Math.PI * 2);\n                ctx.fill();\n\n                // Fish tail\n                ctx.fillStyle = this.getSpeciesColor();\n                ctx.beginPath();\n                ctx.moveTo(-this.size, -this.size * 0.4);\n                ctx.lineTo(-this.size - this.size * 0.5, -this.size * 0.8);\n                ctx.lineTo(-this.size - this.size * 0.5, this.size * 0.8);\n                ctx.closePath();\n                ctx.fill();\n\n                // Fish eye\n                ctx.fillStyle = 'white';\n                ctx.beginPath();\n                ctx.arc(this.size * 0.4, -this.size * 0.2, this.size * 0.15, 0, Math.PI * 2);\n                ctx.fill();\n\n                ctx.restore();\n            }\n\n            getSpeciesColor() {\n                switch (this.species) {\n                    case 'tiny': return '#FFD700';\n                    case 'small': return '#87CEEB';\n                    case 'medium': return '#20B2AA';\n                    case 'large': return '#FF6347';\n                    case 'predator': return '#8B0000';\n                    default: return '#4169E1';\n                }\n            }\n        }\n\n        // ==========================================\n        // PLAYER SYSTEM\n        // ==========================================\n        class Player {\n            constructor() {\n                this.x = CONFIG.gameWidth / 2;\n                this.y = CONFIG.gameHeight / 2;\n                this.size = CONFIG.playerStartSize;\n                this.vx = 0;\n                this.vy = 0;\n                this.angle = 0;\n                this.health = 100;\n                this.hunger = 100;\n                this.score = 0;\n                this.coins = 0;\n                this.experiencePoints = 0;\n                this.evolutionStage = 0;\n                this.isBoosting = false;\n                this.canAttack = false;\n                this.attackCooldown = 0;\n                this.survivalTime = 0;\n                this.baseSpeed = 3;\n                this.boostSpeed = 6;\n            }\n\n            update(inputSystem) {\n                // Movement\n                let moveX = 0;\n                let moveY = 0;\n\n                if (inputSystem.keys['w']) moveY -= 1;\n                if (inputSystem.keys['s']) moveY += 1;\n                if (inputSystem.keys['a']) moveX -= 1;\n                if (inputSystem.keys['d']) moveX += 1;\n\n                // Normalize diagonal movement\n                if (moveX !== 0 || moveY !== 0) {\n                    const length = Math.sqrt(moveX * moveX + moveY * moveY);\n                    moveX /= length;\n                    moveY /= length;\n                    this.angle = Math.atan2(moveY, moveX);\n                }\n\n                // Speed boost\n                this.isBoosting = inputSystem.keys['shift'] && this.hunger > 10;\n                const speed = this.isBoosting ? this.boostSpeed : this.baseSpeed;\n\n                this.vx = moveX * speed * (this.size / CONFIG.playerStartSize);\n                this.vy = moveY * speed * (this.size / CONFIG.playerStartSize);\n\n                // Update position\n                this.x += this.vx;\n                this.y += this.vy;\n\n                // Boundary wrapping\n                if (this.x < 0) this.x = CONFIG.gameWidth;\n                if (this.x > CONFIG.gameWidth) this.x = 0;\n                if (this.y < 0) this.y = CONFIG.gameHeight;\n                if (this.y > CONFIG.gameHeight) this.y = 0;\n\n                // Hunger system\n                let hungerLoss = CONFIG.hungerDecayRate;\n                if (this.isBoosting) hungerLoss += CONFIG.boostCost;\n                this.hunger = Math.max(0, this.hunger - hungerLoss);\n\n                // Health system (lose health if hungry)\n                if (this.hunger === 0) {\n                    this.health -= 0.5;\n                }\n\n                // Survival time\n                this.survivalTime += 1 / 60; // Assuming 60 FPS\n\n                // Attack cooldown\n                if (this.attackCooldown > 0) {\n                    this.attackCooldown--;\n                } else {\n                    this.canAttack = true;\n                }\n            }\n\n            attack() {\n                if (!this.canAttack || this.attackCooldown > 0) return false;\n                this.attackCooldown = 30; // Half second cooldown at 60 FPS\n                this.canAttack = false;\n                return true;\n            }\n\n            eat(fish) {\n                const sizeGain = fish.size * 0.3;\n                this.size += sizeGain;\n                this.experiencePoints += fish.size * 2;\n                this.score += Math.floor(fish.size * 10);\n                this.coins += Math.floor(fish.size * 0.5);\n                this.hunger = Math.min(100, this.hunger + 15);\n                this.health = Math.min(100, this.health + 5);\n\n                // Evolution check\n                this.checkEvolution();\n            }\n\n            checkEvolution() {\n                const stages = [\n                    { name: 'Tiny Fish', maxSize: 3, abilities: [] },\n                    { name: 'Small Fish', maxSize: 8, abilities: ['dash'] },\n                    { name: 'Hunter Fish', maxSize: 15, abilities: ['bite'] },\n                    { name: 'Shark', maxSize: 30, abilities: ['charge'] },\n                    { name: 'Mega Shark', maxSize: 40, abilities: ['whirlwind'] },\n                    { name: 'Leviathan', maxSize: 50, abilities: ['tsunami'] },\n                ];\n\n                for (let i = 0; i < stages.length; i++) {\n                    if (this.size >= stages[i].maxSize && this.evolutionStage < i) {\n                        this.evolutionStage = i;\n                        this.baseSpeed += 0.5;\n                        this.health = 100;\n                        menuSystem.showNotification(`EVOLUTION! You are now a ${stages[i].name}!`);\n                        particleSystem.addBubbles(this.x, this.y, 20);\n                        break;\n                    }\n                }\n            }\n\n            draw(ctx, offsetX, offsetY) {\n                const screenX = this.x - offsetX;\n                const screenY = this.y - offsetY;\n\n                ctx.save();\n                ctx.translate(screenX, screenY);\n                ctx.rotate(this.angle);\n\n                // Player body - gradient\n                const gradient = ctx.createRadialGradient(0, 0, 0, 0, 0, this.size);\n                gradient.addColorStop(0, '#00FF88');\n                gradient.addColorStop(1, '#00AA44');\n                ctx.fillStyle = gradient;\n                ctx.beginPath();\n                ctx.ellipse(0, 0, this.size, this.size * 0.7, 0, 0, Math.PI * 2);\n                ctx.fill();\n\n                // Player outline\n                ctx.strokeStyle = '#00FFAA';\n                ctx.lineWidth = 2;\n                ctx.stroke();\n\n                // Fins\n                ctx.fillStyle = 'rgba(0, 255, 136, 0.5)';\n                ctx.beginPath();\n                ctx.ellipse(0, -this.size * 0.7, this.size * 0.4, this.size * 0.3, 0, 0, Math.PI * 2);\n                ctx.fill();\n\n                // Tail\n                ctx.fillStyle = '#00FF88';\n                ctx.beginPath();\n                ctx.moveTo(-this.size, -this.size * 0.5);\n                ctx.lineTo(-this.size - this.size * 0.6, -this.size * 0.9);\n                ctx.lineTo(-this.size - this.size * 0.6, this.size * 0.9);\n                ctx.closePath();\n                ctx.fill();\n\n                // Eye\n                ctx.fillStyle = 'white';\n                ctx.beginPath();\n                ctx.arc(this.size * 0.5, -this.size * 0.25, this.size * 0.2, 0, Math.PI * 2);\n                ctx.fill();\n\n                // Pupil\n                ctx.fillStyle = 'black';\n                ctx.beginPath();\n                ctx.arc(this.size * 0.55, -this.size * 0.2, this.size * 0.1, 0, Math.PI * 2);\n                ctx.fill();\n\n                // Glow effect when boosting\n                if (this.isBoosting) {\n                    ctx.strokeStyle = 'rgba(0, 255, 255, 0.4)';\n                    ctx.lineWidth = 3;\n                    ctx.beginPath();\n                    ctx.ellipse(0, 0, this.size + 5, this.size * 0.7 + 5, 0, 0, Math.PI * 2);\n                    ctx.stroke();\n                }\n\n                ctx.restore();\n            }\n\n            getEvolutionName() {\n                const names = ['Tiny Fish', 'Small Fish', 'Hunter Fish', 'Shark', 'Mega Shark', 'Leviathan'];\n                return names[this.evolutionStage] || 'Unknown';\n            }\n        }\n\n        // ==========================================\n        // WORLD GENERATION\n        // ==========================================\n        const worldGenerator = {\n            generateFood: function(count) {\n                const food = [];\n                for (let i = 0; i < count; i++) {\n                    food.push(new Fish(\n                        Math.random() * CONFIG.gameWidth,\n                        Math.random() * CONFIG.gameHeight,\n                        Math.random() * 2 + 0.5,\n                        'tiny'\n                    ));\n                }\n                return food;\n            },\n\n            generateFishSchool: function(count) {\n                const school = [];\n                for (let i = 0; i < count; i++) {\n                    const species = Math.random() > 0.7 ? 'medium' : 'small';\n                    const size = species === 'medium' ? Math.random() * 3 + 2 : Math.random() * 2 + 1;\n                    school.push(new Fish(\n                        Math.random() * CONFIG.gameWidth,\n                        Math.random() * CONFIG.gameHeight,\n                        size,\n                        species\n                    ));\n                }\n                return school;\n            },\n\n            generatePredators: function(count) {\n                const predators = [];\n                for (let i = 0; i < count; i++) {\n                    predators.push(new Fish(\n                        Math.random() * CONFIG.gameWidth,\n                        Math.random() * CONFIG.gameHeight,\n                        Math.random() * 5 + 5,\n                        'predator'\n                    ));\n                }\n                return predators;\n            },\n\n            drawEnvironment: function(offsetX, offsetY) {\n                // Deep sea background layers\n                const depthColor = Math.floor((offsetY / CONFIG.gameHeight) * 255);\n                \n                // Terrain features\n                const terrainX = Math.floor(offsetX / 500) * 500;\n                const terrainY = Math.floor(offsetY / 500) * 500;\n\n                // Draw coral reefs\n                if ((terrainX + terrainY) % 1000 === 0) {\n                    ctx.fillStyle = 'rgba(255, 140, 0, 0.3)';\n                    ctx.fillRect(\n                        terrainX - offsetX,\n                        terrainY - offsetY,\n                        200,\n                        200\n                    );\n                }\n\n                // Draw sand areas\n                if ((terrainX ^ terrainY) % 700 === 0) {\n                    ctx.fillStyle = 'rgba(210, 180, 140, 0.2)';\n                    ctx.fillRect(\n                        terrainX - offsetX,\n                        terrainY - offsetY,\n                        300,\n                        300\n                    );\n                }\n            },\n        };\n\n        // ==========================================\n        // INPUT SYSTEM\n        // ==========================================\n        const inputSystem = {\n            keys: {},\n            mouseX: 0,\n            mouseY: 0,\n\n            init: function() {\n                document.addEventListener('keydown', (e) => {\n                    this.keys[e.key.toLowerCase()] = true;\n                });\n\n                document.addEventListener('keyup', (e) => {\n                    this.keys[e.key.toLowerCase()] = false;\n                });\n\n                document.addEventListener('mousemove', (e) => {\n                    this.mouseX = e.clientX;\n                    this.mouseY = e.clientY;\n                });\n\n                document.addEventListener('mousedown', (e) => {\n                    if (e.button === 0 && gameEngine.isRunning) {\n                        gameEngine.handleAttack();\n                    }\n                });\n            },\n        };\n\n        // ==========================================\n        // MENU SYSTEM\n        // ==========================================\n        const menuSystem = {\n            settings: {\n                sound: true,\n                music: true,\n                particles: true,\n            },\n\n            showControls: function() {\n                document.getElementById('startMenu').classList.remove('active');\n                document.getElementById('controlsScreen').classList.add('active');\n            },\n\n            hideControls: function() {\n                document.getElementById('controlsScreen').classList.remove('active');\n                document.getElementById('startMenu').classList.add('active');\n            },\n\n            showSettings: function() {\n                document.getElementById('settingsMenu').classList.add('active');\n            },\n\n            hideSettings: function() {\n                document.getElementById('settingsMenu').classList.remove('active');\n            },\n\n            toggleSound: function() {\n                this.settings.sound = !this.settings.sound;\n                document.getElementById('soundToggle').classList.toggle('on');\n            },\n\n            toggleMusic: function() {\n                this.settings.music = !this.settings.music;\n                document.getElementById('musicToggle').classList.toggle('on');\n            },\n\n            toggleParticles: function() {\n                this.settings.particles = !this.settings.particles;\n                document.getElementById('particlesToggle').classList.toggle('on');\n            },\n\n            showNotification: function(text) {\n                const notif = document.createElement('div');\n                notif.className = 'notification';\n                notif.style.display = 'block';\n                notif.textContent = text;\n                document.body.appendChild(notif);\n                setTimeout(() => notif.remove(), 3000);\n            },\n        };\n\n        // ==========================================\n        // GAME ENGINE\n        // ==========================================\n        const gameEngine = {\n            isRunning: false,\n            isPaused: false,\n            player: null,\n            foodList: [],\n            fishSchool: [],\n            predators: [],\n            lastFrameTime: 0,\n            deltaTime: 0,\n            gameStats: {\n                maxScore: 0,\n                totalCoins: 0,\n                maxEvolution: 'Tiny Fish',\n            },\n            canRevive: true,\n            revivedThisRun: false,\n\n            startGame: function() {\n                document.getElementById('startMenu').classList.remove('active');\n                document.getElementById('gameOverScreen').classList.remove('active');\n                \n                this.isRunning = true;\n                this.isPaused = false;\n                this.revivedThisRun = false;\n                this.canRevive = true;\n\n                this.player = new Player();\n                this.foodList = worldGenerator.generateFood(200);\n                this.fishSchool = worldGenerator.generateFishSchool(CONFIG.fishSchoolSize);\n                this.predators = worldGenerator.generatePredators(CONFIG.predatorCount);\n\n                this.gameLoop();\n            },\n\n            pause: function() {\n                this.isPaused = true;\n                document.getElementById('pauseMenu').classList.add('active');\n            },\n\n            resume: function() {\n                this.isPaused = false;\n                document.getElementById('pauseMenu').classList.remove('active');\n            },\n\n            returnToMenu: function() {\n                this.isRunning = false;\n                this.isPaused = false;\n                document.getElementById('pauseMenu').classList.remove('active');\n                document.getElementById('gameOverScreen').classList.remove('active');\n                document.getElementById('startMenu').classList.add('active');\n                yandexSDK.saveProgress(this.gameStats);\n                adSystem.showInterstitialAd();\n            },\n\n            gameOver: function() {\n                this.isRunning = false;\n                \n                // Update stats\n                if (this.player.score > this.gameStats.maxScore) {\n                    this.gameStats.maxScore = this.player.score;\n                }\n                if (this.player.coins > this.gameStats.totalCoins) {\n                    this.gameStats.totalCoins = this.player.coins;\n                }\n                this.gameStats.maxEvolution = this.player.getEvolutionName();\n\n                // Show game over screen\n                document.getElementById('finalScore').textContent = Math.floor(this.player.score);\n                document.getElementById('totalCoins').textContent = Math.floor(this.player.coins);\n                document.getElementById('maxEvolution').textContent = this.player.getEvolutionName();\n                document.getElementById('survivalTime').textContent = Math.floor(this.player.survivalTime) + 's';\n                document.getElementById('gameOverScreen').classList.add('active');\n            },\n\n            requestRevive: function() {\n                if (!this.canRevive || this.revivedThisRun) {\n                    menuSystem.showNotification('You can only revive once per run!');\n                    return;\n                }\n\n                adSystem.showRewardedAd('revive').then((success) => {\n                    if (success) {\n                        this.revivedThisRun = true;\n                        this.canRevive = false;\n                        this.isRunning = true;\n                        this.player.health = 100;\n                        this.player.hunger = 80;\n                        document.getElementById('gameOverScreen').classList.remove('active');\n                        menuSystem.showNotification('Revived! Keep fighting!');\n                        this.gameLoop();\n                    }\n                });\n            },\n\n            handleAttack: function() {\n                if (!this.isRunning || !this.player) return;\n                \n                if (this.player.attack()) {\n                    // Check for hits in attack radius\n                    const attackRadius = this.player.size * 2;\n                    const attackX = this.player.x + Math.cos(this.player.angle) * attackRadius;\n                    const attackY = this.player.y + Math.sin(this.player.angle) * attackRadius;\n\n                    // Check fish school\n                    for (let i = this.fishSchool.length - 1; i >= 0; i--) {\n                        const fish = this.fishSchool[i];\n                        if (collisionSystem.checkCircleCollision(\n                            attackX, attackY, attackRadius,\n                            fish.x, fish.y, fish.size\n                        )) {\n                            if (fish.size < this.player.size * 0.8) {\n                                this.player.eat(fish);\n                                particleSystem.addBlood(fish.x, fish.y, 5);\n                                this.fishSchool.splice(i, 1);\n                            }\n                        }\n                    }\n\n                    // Check food\n                    for (let i = this.foodList.length - 1; i >= 0; i--) {\n                        const food = this.foodList[i];\n                        if (collisionSystem.checkCircleCollision(\n                            attackX, attackY, attackRadius,\n                            food.x, food.y, food.size\n                        )) {\n                            this.player.eat(food);\n                            particleSystem.addBubbles(food.x, food.y, 3);\n                            this.foodList.splice(i, 1);\n                        }\n                    }\n                }\n            },\n\n            update: function() {\n                if (!this.player) return;\n\n                // Check for escape key (pause)\n                if (inputSystem.keys['escape']) {\n                    inputSystem.keys['escape'] = false;\n                    if (this.isPaused) {\n                        this.resume();\n                    } else {\n                        this.pause();\n                    }\n                }\n\n                if (this.isPaused) return;\n\n                // Update player\n                this.player.update(inputSystem);\n\n                // Update AI entities\n                this.fishSchool.forEach(fish => fish.update());\n                this.predators.forEach(predator => predator.update());\n\n                // Check collisions with predators\n                this.predators.forEach(predator => {\n                    if (collisionSystem.checkCircleCollision(\n                        this.player.x, this.player.y, this.player.size,\n                        predator.x, predator.y, predator.size\n                    )) {\n                        if (predator.size > this.player.size * 1.2) {\n                            this.player.health -= 10;\n                        } else if (this.player.size > predator.size * 1.2) {\n                            this.player.eat(predator);\n                            const idx = this.predators.indexOf(predator);\n                            if (idx > -1) this.predators.splice(idx, 1);\n                        }\n                    }\n                });\n\n                // Check collisions with fish school\n                this.fishSchool = this.fishSchool.filter(fish => {\n                    if (collisionSystem.checkCircleCollision(\n                        this.player.x, this.player.y, this.player.size,\n                        fish.x, fish.y, fish.size\n                    )) {\n                        if (fish.size < this.player.size * 0.8) {\n                            this.player.eat(fish);\n                            particleSystem.addBubbles(fish.x, fish.y, 2);\n                            return false;\n                        }\n                    }\n                    return true;\n                });\n\n                // Check collisions with food\n                this.foodList = this.foodList.filter(food => {\n                    if (collisionSystem.checkCircleCollision(\n                        this.player.x, this.player.y, this.player.size,\n                        food.x, food.y, food.size\n                    )) {\n                        this.player.eat(food);\n                        particleSystem.addBubbles(food.x, food.y, 2);\n                        return false;\n                    }\n                    return true;\n                });\n\n                // Respawn food if needed\n                if (this.foodList.length < 100) {\n                    this.foodList = this.foodList.concat(\n                        worldGenerator.generateFood(50)\n                    );\n                }\n\n                // Respawn fish school if needed\n                if (this.fishSchool.length < CONFIG.fishSchoolSize * 0.5) {\n                    this.fishSchool = this.fishSchool.concat(\n                        worldGenerator.generateFishSchool(50)\n                    );\n                }\n\n                // Check game over condition\n                if (this.player.health <= 0) {\n                    this.gameOver();\n                }\n\n                // Update particles\n                particleSystem.update();\n            },\n\n            draw: function() {\n                if (!this.player) return;\n\n                // Camera follows player\n                const cameraX = this.player.x - canvas.width / 2;\n                const cameraY = this.player.y - canvas.height / 2;\n\n                // Draw background based on depth\n                const depthRatio = cameraY / CONFIG.gameHeight;\n                const bgColor = `rgb(${Math.floor(10 + depthRatio * 30)}, ${Math.floor(74 + depthRatio * 50)}, ${Math.floor(122 + depthRatio * 80)})`;\n                ctx.fillStyle = bgColor;\n                ctx.fillRect(0, 0, canvas.width, canvas.height);\n\n                // Draw world\n                worldGenerator.drawEnvironment(cameraX, cameraY);\n\n                // Draw entities\n                this.foodList.forEach(food => food.draw(ctx, cameraX, cameraY));\n                this.fishSchool.forEach(fish => fish.draw(ctx, cameraX, cameraY));\n                this.predators.forEach(predator => predator.draw(ctx, cameraX, cameraY));\n                this.player.draw(ctx, cameraX, cameraY);\n\n                // Draw particles\n                particleSystem.draw(ctx, cameraX, cameraY);\n\n                // Update HUD\n                document.getElementById('scoreDisplay').textContent = Math.floor(this.player.score);\n                document.getElementById('coinsDisplay').textContent = Math.floor(this.player.coins);\n                document.getElementById('sizeDisplay').textContent = this.player.size.toFixed(1);\n                document.getElementById('evolutionStageDisplay').textContent = this.player.getEvolutionName();\n                document.getElementById('healthDisplay').textContent = Math.floor(this.player.health) + '%';\n                document.getElementById('hungerDisplay').textContent = Math.floor(this.player.hunger) + '%';\n\n                // Update evolution bar\n                const evolutionPercentage = ((this.player.evolutionStage + 1) / 6) * 100;\n                document.getElementById('evolutionFill').style.width = evolutionPercentage + '%';\n                document.getElementById('evolutionText').textContent = Math.floor(evolutionPercentage) + '%';\n            },\n\n            gameLoop: function() {\n                const currentTime = performance.now();\n                this.deltaTime = (currentTime - this.lastFrameTime) / 1000;\n                this.lastFrameTime = currentTime;\n\n                this.update();\n                this.draw();\n\n                if (this.isRunning) {\n                    requestAnimationFrame(() => this.gameLoop());\n                }\n            },\n        };\n\n        // ==========================================\n        // INITIALIZATION\n        // ==========================================\n        document.addEventListener('DOMContentLoaded', () => {\n            inputSystem.init();\n            yandexSDK.init();\n        });\n    </script>\n</body>\n</html>